#!/data/data/com.termux/files/usr/bin/bash

# 1. تنظيف الشاشة وتحديث تيرمكس
clear
echo "[-] جاري تحديث نظام تيرمكس وتثبيت بايثون..."
pkg update -y && pkg upgrade -y
pkg install python -y

# 2. إنشاء مجلد الأداة في جهازك
mkdir -p $HOME/pak_extractor
cd $HOME/pak_extractor

# 3. كتابة كود البايثون المخصص لفك الملفات داخل جهازك
cat << 'EOF' > extractor.py
import os
import sys
import struct

def extract_pak(pak_path, out_dir):
    if not os.path.exists(pak_path):
        print(f"[-] الملف غير موجود في هذا المسار: {pak_path}")
        return
    if not os.path.exists(out_dir):
        os.makedirs(out_dir)

    with open(pak_path, 'rb') as f:
        magic = f.read(4)
        if magic != b'PACK':
            print("[-] خطأ: هذا الملف ليس ملف PAK قياسي (ربما مشفر).")
            return
        offset, size = struct.unpack('<II', f.read(8))
        f.seek(offset)
        num_files = size // 64
        print(f"[+] تم العثور على {num_files} ملف. جاري الاستخراج...")
        for _ in range(num_files):
            file_name = f.read(56).decode('utf-8', errors='ignore').strip('\x00')
            file_offset, file_size = struct.unpack('<II', f.read(8))
            current_pos = f.tell()
            f.seek(file_offset)
            file_data = f.read(file_size)
            target_path = os.path.join(out_dir, file_name)
            target_subdir = os.path.dirname(target_path)
            if not os.path.exists(target_subdir):
                os.makedirs(target_subdir)
            with open(target_path, 'wb') as out_file:
                out_file.write(file_data)
            print(f"[+] استخراج: {file_name}")
            f.seek(current_pos)

if __name__ == "__main__":
    if len(sys.argv) < 3:
        print("الاستخدام: pak-extract [مسار_ملف_PAK] [مجلد_المخرجات]")
    else:
        extract_pak(sys.argv[1], sys.argv[2])
EOF

# 4. جعل الأداة أمر رسمي في تيرمكس باسم pak-extract
echo 'python $HOME/pak_extractor/extractor.py "$@"' > $PREFIX/bin/pak-extract
chmod +x $PREFIX/bin/pak-extract

clear
echo "========================================="
echo "   تم تثبيت الأداة بنجاح في جهازك!      "
echo "========================================="
echo " للاستخدام اكتب: pak-extract [المسار] [مجلد_الحفظ]"
